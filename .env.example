# Supabase
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# CLIProxy
CLIPROXY_BASE_URL=http://localhost:8317/v1
CLIPROXY_API_KEY=your-cliproxy-api-key
CLIPROXY_MODEL_OPUS=claude-opus-4-6

# Resend webhook verification (not per-org — shared infrastructure)
RESEND_WEBHOOK_SECRET=whsec_your_webhook_secret

# --- Per-org credentials (transition fallbacks) ---
# These are used when org_secrets has NULL values. Migrate to org_secrets for multi-org.
RESEND_API_KEY=re_your_api_key
RESEND_FROM_DOMAIN=mail.example.com
OWNER_EMAIL=owner@example.com
DEFAULT_ORG_ID=your-org-uuid

# Engine
PORT=3001
TASK_TIMEOUT_MS=600000

# Web (packages/web/.env.local)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_ENGINE_URL=http://localhost:3001

# CORS (comma-separated origins allowed by the engine)
CORS_ORIGINS=http://localhost:3000

# Public URLs (used in GitHub App setup, email links, etc.)
ENGINE_PUBLIC_URL=http://localhost:3001
WEB_PUBLIC_URL=http://localhost:3000
APP_URL=http://localhost:3000
