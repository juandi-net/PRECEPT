# Supabase
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# CLIProxy
CLIPROXY_BASE_URL=http://localhost:8317/v1
CLIPROXY_API_KEY=your-cliproxy-api-key
CLIPROXY_MODEL_OPUS=claude-opus-4-6

# Resend
RESEND_API_KEY=re_your_api_key
RESEND_FROM_DOMAIN=mail.rookiesports.org
RESEND_WEBHOOK_SECRET=whsec_your_webhook_secret
OWNER_EMAIL=juandi@example.com

# Engine
PORT=3001
DEFAULT_ORG_ID=your-org-uuid
TASK_TIMEOUT_MS=600000
